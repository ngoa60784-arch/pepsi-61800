{
    "identifier": "default",
    "description": "BreachWeave desktop default permissions",
    "windows": ["main"],
    "webviews": ["main"],
    "remote": {
        "urls": [
            "http://127.0.0.1:38472",
            "http://127.0.0.1:38472/*",
            "http://localhost:38472",
            "http://localhost:38472/*"
        ]
    },
    "permissions": [
        "core:default",
        "core:event:default",
        "allow-desktop-confirm-exit",
        "core:window:allow-create",
        "core:window:allow-set-focus",
        "core:window:allow-unminimize",
        "core:window:allow-show",
        "core:webview:allow-create-webview-window",
        "shell:allow-kill",
        {
            "identifier": "shell:allow-execute",
            "allow": [
                {
                    "name": "binaries/tch-agent",
                    "sidecar": true,
                    "args": true
                },
                {
                    "name": "bun",
                    "cmd": "bun",
                    "args": true
                }
            ]
        },
        {
            "identifier": "shell:allow-spawn",
            "allow": [
                {
                    "name": "binaries/tch-agent",
                    "sidecar": true,
                    "args": true
                },
                {
                    "name": "bun",
                    "cmd": "bun",
                    "args": true
                }
            ]
        }
    ]
}
