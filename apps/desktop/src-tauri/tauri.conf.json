{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "BreachWeave",
    "version": "0.0.14",
    "identifier": "ai.tch-agent.breachweave",
    "build": {
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": ["deb", "rpm"],
        "externalBin": ["binaries/tch-agent"],
        "linux": {
            "deb": {
                "files": {
                    "/usr/bin/package.json": "binaries/package.json"
                }
            },
            "rpm": {
                "files": {
                    "/usr/bin/package.json": "binaries/package.json"
                }
            }
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
