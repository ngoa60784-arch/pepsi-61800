{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "BreachWeave",
    "version": "0.0.8",
    "identifier": "ai.tch-agent.breachweave",
    "build": {
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [],
        "security": {
            "csp": "default-src 'self' http://127.0.0.1:38472 http://localhost:38472; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost http://127.0.0.1:38472 http://localhost:38472; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
        }
    },
    "bundle": {
        "active": true,
        "targets": ["deb", "rpm"],
        "externalBin": ["binaries/tch-agent"],
        "linux": {
            "deb": {
                "files": {
                    "/usr/bin/package.json": "binaries/package.json"
                }
            },
            "rpm": {
                "files": {
                    "/usr/bin/package.json": "binaries/package.json"
                }
            }
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
