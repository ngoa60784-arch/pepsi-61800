{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": ".",
        "composite": true,
        "paths": {
            "@tch/core": ["./packages/core/src/index.ts"],
            "@tch/ui-web": ["./packages/ui-web/src/index.ts"],
            "@tch/ui-tui": ["./packages/ui-tui/src/index.ts"]
        }
    },
    "references": [{ "path": "packages/core" }, { "path": "packages/ui-web" }, { "path": "packages/ui-tui" }, { "path": "apps/cli" }],
    "exclude": ["node_modules.bak", "dist", "apps/*/dist", "packages/*/dist", "packages/libs/*/dist"]
}
