{
    "name": "tch-agent",
    "version": "0.0.2",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*",
        "packages/libs/*",
        "apps/*"
    ],
    "scripts": {
        "install": "bun run scripts/install.ts",
        "start": "bun run apps/cli/src/main.ts",
        "web": "bun run apps/cli/src/main.ts web",
        "tui": "bun run apps/cli/src/main.ts",
        "dev": "bun apps/cli/src/main.ts web",
        "dev:hot": "bun --hot apps/cli/src/main.ts web",
        "build:kimi-gateway-test:linux": "bun build --compile ./scripts/test-kimi-gateway.ts --outfile ./bin/test-kimi-gateway-linux-x64 --target bun-linux-x64-baseline",
        "build": "bun run build:linux && bun run build:macos-arm64 && bun run build:macos-x64 && bun run build:windows && cp package.json bin/",
        "build:linux": "bun run scripts/build.ts bun-linux-x64-baseline bin/tch-agent-linux-x64",
        "build:macos-arm64": "bun run scripts/build.ts bun-darwin-arm64 bin/tch-agent-darwin-arm64",
        "build:macos-x64": "bun run scripts/build.ts bun-darwin-x64 bin/tch-agent-darwin-x64",
        "build:windows": "bun run scripts/build.ts bun-windows-x64-baseline bin/tch-agent-windows-x64.exe",
        "typecheck": "bun ./node_modules/typescript/bin/tsc --noEmit -p packages/core",
        "typecheck:web": "bun ./node_modules/typescript/bin/tsc --noEmit -p packages/ui-web",
        "typecheck:cli": "bun ./node_modules/typescript/bin/tsc --noEmit -p apps/cli",
        "typecheck:all": "bun run typecheck && bun run typecheck:web && bun run typecheck:cli",
        "desktop:prepare": "bun run scripts/prepare-desktop-sidecar.ts --platform=linux",
        "desktop:prepare:dev": "bun run scripts/prepare-desktop-sidecar.ts --dev",
        "desktop:prepare:all": "bun run scripts/prepare-desktop-sidecar.ts --all-platforms",
        "desktop:prepare:windows": "bun run scripts/prepare-desktop-sidecar.ts --platform=windows",
        "desktop:prepare:macos": "bun run scripts/prepare-desktop-sidecar.ts --platform=macos-arm64 --platform=macos-x64",
        "desktop:dev": "bash scripts/desktop-dev.sh",
        "desktop:smoke": "bash scripts/smoke-desktop-sidecar.sh",
        "desktop:deps": "bash scripts/install-desktop-deps.sh",
        "desktop:build": "bash scripts/pack-desktop.sh",
        "desktop:build:windows": "bash scripts/pack-desktop-windows.sh",
        "desktop:build:macos": "bash scripts/pack-desktop-macos.sh",
        "desktop:build:all": "bash scripts/pack-desktop-all.sh",
        "desktop:build:appimage": "cd apps/desktop && bun run tauri build -- --bundles appimage"
    },
    "module": "index.ts",
    "devDependencies": {
        "@types/bun": "latest",
        "bun-plugin-tailwind": "^0.1.2",
        "tailwindcss": "^4.0.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
