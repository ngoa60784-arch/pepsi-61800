{
    "compilerOptions": {
        "baseUrl": ".",
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "experimentalDecorators": true,
        "paths": {
            "@tch/core": ["../core/src/index.ts"]
        },
        "esModuleInterop": true,
        "strict": true,
        "noImplicitAny": false,
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "composite": true
    },
    "include": ["src", "../core/src"],
    "exclude": ["dist"]
}
