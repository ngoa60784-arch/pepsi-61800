{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "rootDir": "src",
        "outDir": "dist",
        "jsx": "react-jsx",
        "composite": true
    },
    "include": ["src"],
    "exclude": ["dist"],
    "references": [{ "path": "../core" }]
}
